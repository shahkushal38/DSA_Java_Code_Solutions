    public boolean isSafe(boolean[][] dp, int row, int column){
        if(dp[row][column]){
        	return false;
        }
	
	    return true;
    }

    public void updateDp(boolean[][] dp, int row, int column, int n){
    	//row and column
    	for(int i=0; i<n;i++){
    		dp[row][i] = true;
    		dp[i][column] = true;
    	}
    	
    	// check upper left diagonal
    	for (int i = row, j = column; i >= 0 && j >= 0; i--, j--) {
    		dp[i][j] = true;
    	}
    	
    	// check lower right diagonal
    	for (int i = row, j = column; i < n && j < n; i++, j++) {
    		dp[i][j] = true;
    	}
    	
    	// check lower left diagonal
    	for (int i = row, j = column; i < n && j >= 0; i++, j--) {
    		dp[i][j] = true;
    	}
    	
    	// check upper right diagonal
    	for (int i = row, j = column; i>=0 && j < n; i--, j++) {
    		dp[i][j] = true;
    	}
    	
    
    		
    }

    public void solve(int row, boolean[][] dp, int n, ArrayList<ArrayList<Integer>> ans, ArrayList<Integer> arr){
        if(row >= n){
        	if(arr.size() == n)
        		ans.add(new ArrayList<Integer>(arr));
        	
        	return;	
        }
        
        for(int i = 0;i<n;i++){
            // System.out.println(row+" -- "+i+ " -- "+ dp[row][i]);
            
        	if(isSafe(dp, row, i)){
        	    
        		if(row >= 0 && row < arr.size()){
        			arr.set(row, i+1);
        		}else{
        			arr.add(i+1);
        		}
        		
        // 		System.out.println(row+" -- "+i+" -- "+ arr);
        		boolean[][] cloneDp = new boolean[n][n];
        		// Best practice for deep copy
                for (int k = 0; k < n; k++) {
                    cloneDp[k] = dp[k].clone();
                }
        		updateDp(cloneDp, row, i, n);
        		solve(row+1, cloneDp, n, ans, arr);
        	}
        }
        return;
    
    }
