optimizing with dp

public int maximumPath(int[][] mat) {
        int n = mat.length;
        int m = mat[0].length;

        for (int i = 1; i < n; i++) {
            for (int j = 0; j < m; j++) {
                int up = mat[i - 1][j];
                int left = (j > 0) ? mat[i - 1][j - 1] : Integer.MIN_VALUE;
                int right = (j < m - 1) ? mat[i - 1][j + 1] : Integer.MIN_VALUE;
                mat[i][j] += Math.max(up, Math.max(left, right));
            }
        }

        int res = Integer.MIN_VALUE;
        for (int j = 0; j < m; j++) {
            res = Math.max(res, mat[n - 1][j]);
        }
        return res;
    }
