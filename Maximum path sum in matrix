  public int calculateMaxSum(int[][] mat, int r, int c,int n, int m, int sum){
    	if(r==n){
    		return sum;
    	}
    	
    	sum += mat[r][c];
    	int sumL = 0;
    	int sumR = 0;
    	int sumD = 0;
    	if(r+1<n && c-1>=0){
    		sumL =  calculateMaxSum(mat,r+1,c-1,n,m, sum);
    	}
    	
    	if(r+1<n && c>=0 && c<m){
    		sumD =  calculateMaxSum(mat, r+1,c,n,m,sum);
    	}
    	
    	if(r+1<n && c+1 < m && c+1 >= 0){
    		sumR =  calculateMaxSum(mat,r+1, c+1, n, m, sum);
    	}
    	
    	return Math.max(sum, Math.max(sumL, Math.max(sumR, sumD)));
    }
 
 public int maximumPath(int[][] mat){
	int c = mat[0].length;
	
	int sum = 0;
	for(int i=0;i<c;i++){
	    
		sum = Math.max(sum, calculateMaxSum(mat, 0, i, mat.length, c, 0));
	}
	
	return sum;
