public boolean isHeap(Node tree) {
        // code here
		
		Queue<Node> queue = new LinkedList<>();
		queue.offer(tree);
		boolean foundEnd = false;
		while(!queue.isEmpty()){
			tree = queue.poll();
			int data = tree.data;
			
			if(foundEnd && (tree.left != null || tree.right != null)){
				return false;
			}
			
			if(tree.left == null && tree.right != null ){
			    return false;    
			
			}			
			if(tree.left != null ){
				if(tree.left.data < data){
					queue.add(tree.left);
				}else{
					return false;
				}
			}
			
			if(tree.right != null){
				if(tree.right.data < data){
					queue.add(tree.right);
				}else{
					return false;
				}
			}
			
			if(tree.left == null || tree.right == null){
				foundEnd = true;
			}
			
		}
        
		return true;
    }





